{
  "name": "lisa-web",
  "private": true,
  "version": "6.7.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ./scripts/set-revision-info.mjs && tsc && vite build && npm run copy-dist",
    "copy-dist": "mkdir -p ../../../dist/lisa-web && cp -r ./dist/* ../../../dist/lisa-web/",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "preview": "vite preview",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(tsx|js|ts|json)\"",
    "clean": "rm -rf ./dist ./node_modules",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "node ./scripts/smoke-test.mjs",
    "test:smoke:build": "npm run build && node ./scripts/smoke-test.mjs"
  },
